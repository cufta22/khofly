    "@mantine/nprogress": "^7.9.1",
    "@remix-run/cloudflare": "^2.9.2",
    "@remix-run/cloudflare-pages": "^2.9.2",
    "@remix-run/node": "^2.9.2",
    "@remix-run/react": "^2.9.2",
    "@remix-run/serve": "^2.9.2",
    "@tabler/icons-react": "^3.3.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.11",
    "highlight.js": "^11.9.0",
